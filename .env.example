# Environment Variables Template
# =================================
#
# How to use this file:
#   1. Copy this file:    cp .env.example .env
#   2. Fill in real values for any var marked REQUIRED
#   3. NEVER commit .env to git (it is gitignored)
#
# Why an example file? So a new developer (or a grader) can immediately
# see what env vars exist without reading source code. Real secrets stay
# out of the repo per the project brief.
#
# In production (Render), set these via the Render dashboard instead.

# ----- Service -----
# Logging level: DEBUG | INFO | WARNING | ERROR
# Default: INFO
LOG_LEVEL=INFO

# Reported in the /health response body.
# Update this when you cut a release.
APP_VERSION=1.0.0

# ----- Optional (only if you later add an LLM fallback) -----
# Uncomment and fill if you decide to add an LLM provider.
# Otherwise, leave these commented — the service runs entirely rule-based.

# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# LLM_MODEL=gpt-4o-mini
# LLM_CONFIDENCE_THRESHOLD=0.6
